# Root .gitignore — backend (server/) + shared safety net

# Dependencies (any depth — safety net for server/)
node_modules/

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Node backend build output
server/build/
server/dist/
coverage/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db